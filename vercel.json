{
  "buildCommand": "npm run build",
  "outputDirectory": "MusicRecommenderFront/dist",
  "installCommand": "npm install && npm --prefix MusicRecommenderFront install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://correct-exec-tool-meetup.trycloudflare.com/api/:path*" },
